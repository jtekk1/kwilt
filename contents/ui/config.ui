<?xml version="1.0" encoding="UTF-8"?>
<!--
  Ixtli — System Settings → Window Management → KWin Scripts → Configure.

  Plasma 6 KWin scripts use Qt Designer XML (.ui) for their config form, NOT
  QML, despite the rest of Plasma being QtQuick-first. KCM bridges the .ui
  to the kcfg schema in contents/config/main.xml via the widget naming
  convention: every widget named `kcfg_<KeyName>` auto-binds to the kcfg
  entry of the same name. Save in the dialog writes kwinrc; main.js reads
  the same values via cfg() at the next reload.

  Discovery requires metadata.json to declare:
    "X-KDE-ConfigModule": "kwin/effects/configs/kcm_kwin4_genericscripted"
-->
<ui version="4.0">
 <class>KWin::IxtliConfigForm</class>
 <widget class="QWidget" name="KWin::IxtliConfigForm">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>460</width>
    <height>380</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Ixtli</string>
  </property>
  <layout class="QFormLayout" name="formLayout">

   <item row="0" column="0">
    <widget class="QLabel" name="layoutLabel">
     <property name="text"><string>Default layout:</string></property>
    </widget>
   </item>
   <item row="0" column="1">
    <widget class="QComboBox" name="kcfg_Layout">
     <item><property name="text"><string>centerTile</string></property></item>
     <item><property name="text"><string>autoGrid</string></property></item>
     <item><property name="text"><string>monocle</string></property></item>
     <item><property name="text"><string>dual</string></property></item>
    </widget>
   </item>

   <item row="1" column="0">
    <widget class="QLabel" name="capAutoGridLabel">
     <property name="text"><string>autoGrid visible cap:</string></property>
    </widget>
   </item>
   <item row="1" column="1">
    <widget class="QSpinBox" name="kcfg_CapAutoGrid">
     <property name="minimum"><number>1</number></property>
     <property name="maximum"><number>12</number></property>
    </widget>
   </item>

   <item row="2" column="0">
    <widget class="QLabel" name="capCenterTileLabel">
     <property name="text"><string>centerTile visible cap:</string></property>
    </widget>
   </item>
   <item row="2" column="1">
    <widget class="QSpinBox" name="kcfg_CapCenterTile">
     <property name="minimum"><number>1</number></property>
     <property name="maximum"><number>9</number></property>
    </widget>
   </item>

   <item row="3" column="0">
    <widget class="QLabel" name="width1Label">
     <property name="text"><string>centerTile N=1 column width:</string></property>
    </widget>
   </item>
   <item row="3" column="1">
    <widget class="QDoubleSpinBox" name="kcfg_CenterTileWidth1">
     <property name="minimum"><double>0.5</double></property>
     <property name="maximum"><double>1.0</double></property>
     <property name="singleStep"><double>0.05</double></property>
     <property name="decimals"><number>2</number></property>
    </widget>
   </item>

   <item row="4" column="0">
    <widget class="QLabel" name="sideWidthLabel">
     <property name="text"><string>centerTile N≥3 side-column width:</string></property>
    </widget>
   </item>
   <item row="4" column="1">
    <widget class="QDoubleSpinBox" name="kcfg_CenterTileSideWidth">
     <property name="minimum"><double>0.15</double></property>
     <property name="maximum"><double>0.45</double></property>
     <property name="singleStep"><double>0.05</double></property>
     <property name="decimals"><number>2</number></property>
    </widget>
   </item>

   <item row="5" column="0">
    <widget class="QLabel" name="outerGapLabel">
     <property name="text"><string>Outer gap (px):</string></property>
    </widget>
   </item>
   <item row="5" column="1">
    <widget class="QSpinBox" name="kcfg_OuterGap">
     <property name="minimum"><number>0</number></property>
     <property name="maximum"><number>80</number></property>
     <property name="suffix"><string> px</string></property>
    </widget>
   </item>

   <item row="6" column="0">
    <widget class="QLabel" name="innerGapLabel">
     <property name="text"><string>Inner gap (px):</string></property>
    </widget>
   </item>
   <item row="6" column="1">
    <widget class="QSpinBox" name="kcfg_InnerGap">
     <property name="minimum"><number>0</number></property>
     <property name="maximum"><number>80</number></property>
     <property name="suffix"><string> px</string></property>
    </widget>
   </item>

   <item row="7" column="0">
    <widget class="QLabel" name="borderlessLabel">
     <property name="text"><string>Hide decorations when tiled:</string></property>
    </widget>
   </item>
   <item row="7" column="1">
    <widget class="QCheckBox" name="kcfg_BorderlessWhenTiled">
     <property name="text"><string/></property>
    </widget>
   </item>

   <item row="8" column="0">
    <widget class="QLabel" name="alwaysFloatLabel">
     <property name="text"><string>Always float (resourceClass, comma-separated):</string></property>
     <property name="wordWrap"><bool>true</bool></property>
    </widget>
   </item>
   <item row="8" column="1">
    <widget class="QLineEdit" name="kcfg_AlwaysFloat">
     <property name="placeholderText"><string>kcalc, pavucontrol, plasma-systemmonitor</string></property>
    </widget>
   </item>

   <item row="9" column="0" colspan="2">
    <widget class="QLabel" name="noteLabel">
     <property name="text">
      <string>Changes apply on the next script reload (toggle Ixtli off and on, or relogin).</string>
     </property>
     <property name="wordWrap"><bool>true</bool></property>
     <property name="styleSheet"><string>color: palette(placeholder-text); font-style: italic;</string></property>
    </widget>
   </item>

  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
