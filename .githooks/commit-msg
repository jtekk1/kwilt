#
# Validates a commit message against Conventional Commits 1.0.0.
#   https://www.conventionalcommits.org/en/v1.0.0/
#
# Usage as a git hook: git passes the commit message file path as $1.
# Usage standalone:    .githooks/commit-msg <path-to-message-file>

set -euo pipefail

msg_file="${1:?usage: commit-msg <message-file>}"
subject=$(head -1 "$msg_file")

# Skip merge / revert / fixup / squash commits — git generates these.
case "$subject" in
    "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

# <type>(<optional scope>)?!?: <subject>
regex='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([^)]+\))?!?: .+'

if [[ ! "$subject" =~ $regex ]]; then
    echo "Commit message does not follow Conventional Commits 1.0.0:" >&2
    echo "    $subject" >&2
    echo >&2
    echo "Expected: <type>(<scope>)?!?: <subject>" >&2
    echo "Types:    feat fix docs style refactor perf test build ci chore revert" >&2
    echo "Examples:" >&2
    echo "    feat(centerTile): add 8-window slot for ultrawide displays" >&2
    echo "    fix: unmaximize before setting frameGeometry" >&2
    echo "    chore!: drop autoGrid layout (breaking change)" >&2
    echo >&2
    echo "Spec: https://www.conventionalcommits.org/en/v1.0.0/" >&2
    exit 1
fi
